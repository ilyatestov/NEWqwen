# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID канала для публикаций (с -100 в начале)
CHANNEL_ID=-1001234567890

# Ваш Telegram ID (администратор)
ADMIN_ID=123456789

# Интервал проверки RSS лент (секунды, по умолчанию 300 = 5 минут)
CHECK_INTERVAL=300

# Путь к базе данных
DB_PATH=/app/data/seen_posts.db

# Максимальное количество записей в БД (для автоочистки)
MAX_DB_ENTRIES=10000

# Таймаут запроса к RSS ленте (секунды)
RSS_TIMEOUT=10

# Количество постов для проверки за один раз
POSTS_TO_CHECK=5
