# RSS Sentinel Configuration

# Telegram Bot Token (required)
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs (comma-separated, required)
# Use @userinfobot to get your Telegram ID
ADMIN_IDS=123456789

# Secret key for sessions (change in production!)
SECRET_KEY=change-me-to-random-string-in-production

# Web server port
WEB_PORT=8000

# RSS check interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300

# Telegram Channel ID (optional, for publishing)
# Use @getmyidbot to get channel ID (with -100 prefix)
TELEGRAM_CHANNEL_ID=

# VK Group ID (optional)
VK_GROUP_ID=

# Twitter API Key (optional)
TWITTER_API_KEY=
