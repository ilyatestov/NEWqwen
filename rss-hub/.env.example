# RSS Hub Environment Configuration

# Required: Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Required: Comma-separated list of admin Telegram user IDs
ADMIN_IDS=123456789,987654321

# Optional: Default channel/group ID for posting (-100 prefix for supergroups)
CHANNEL_ID=-1001234567890

# Database Configuration
DATABASE_PATH=data/rss_hub.db

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Feed Checking Interval (seconds)
CHECK_INTERVAL=300

# Logging
LOG_LEVEL=INFO

# Environment (development/production)
ENVIRONMENT=production

# Debug Mode (set to true for development)
DEBUG=false

# RSS Parsing Timeout (seconds)
RSS_TIMEOUT=10

# Secret Key for sessions (auto-generated if not set)
# SECRET_KEY=your_secret_key_here
